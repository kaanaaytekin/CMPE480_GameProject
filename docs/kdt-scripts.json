{
  "title": "KDT Test Scripts — ISO/IEC/IEEE 29119 Millionaire",
  "document_id": "KDT-29119M-001",
  "version": "1.0",
  "date": "2026-05-20",
  "course": "CMPE 480 — International Standards on Software Engineering",
  "team": ["Kaan Aytekin", "Müslüm Türker Kırtız", "Yaren Atılgan"],
  "reference": "ISO/IEC/IEEE 29119-5 (Keyword-Driven Testing)",
  "keyword_library": [
    {
      "keyword": "OpenApplication",
      "description": "Navigate to the application URL and wait for the welcome screen to load",
      "parameters": [{ "name": "url", "type": "string" }]
    },
    {
      "keyword": "EnterUsername",
      "description": "Type a username into the name input field",
      "parameters": [{ "name": "username", "type": "string" }]
    },
    {
      "keyword": "ClickStartGame",
      "description": "Click the Start Game button on the welcome screen",
      "parameters": []
    },
    {
      "keyword": "VerifyErrorMessage",
      "description": "Assert that a specific error message is visible",
      "parameters": [{ "name": "expected_text", "type": "string" }]
    },
    {
      "keyword": "SelectMCQAnswer",
      "description": "Click the answer button at the given index (0–3)",
      "parameters": [{ "name": "index", "type": "integer" }]
    },
    {
      "keyword": "SelectTFAnswer",
      "description": "Click either the True or False button",
      "parameters": [{ "name": "value", "type": "string", "allowed_values": ["True", "False"] }]
    },
    {
      "keyword": "TypeFITBAnswer",
      "description": "Type text into the Fill in the Blank input field and submit",
      "parameters": [{ "name": "text", "type": "string" }]
    },
    {
      "keyword": "MatchPair",
      "description": "Click a left-column item and then its corresponding right-column item",
      "parameters": [
        { "name": "left_index", "type": "integer" },
        { "name": "right_text", "type": "string" }
      ]
    },
    {
      "keyword": "ClickConfirmAllPairs",
      "description": "Click the Confirm All Pairs button on a Matching question",
      "parameters": []
    },
    {
      "keyword": "ClickRemoveAll",
      "description": "Click the Remove All button to clear all matching connections",
      "parameters": []
    },
    {
      "keyword": "UseLifeline",
      "description": "Activate a lifeline by name",
      "parameters": [{ "name": "lifeline", "type": "string", "allowed_values": ["fifty", "phone", "audience"] }]
    },
    {
      "keyword": "SelectExpert",
      "description": "Choose an expert in the expert selection modal",
      "parameters": [{ "name": "expert_name", "type": "string" }]
    },
    {
      "keyword": "CloseModal",
      "description": "Close the currently open modal dialog",
      "parameters": []
    },
    {
      "keyword": "ClickWalkAway",
      "description": "Click the Walk Away button and confirm",
      "parameters": []
    },
    {
      "keyword": "VerifyPrizeLadder",
      "description": "Assert that the current highlighted prize matches the expected value",
      "parameters": [{ "name": "expected_prize", "type": "string" }]
    },
    {
      "keyword": "VerifyAnswerState",
      "description": "Assert that an answer button is in the expected visual state",
      "parameters": [
        { "name": "index", "type": "integer" },
        { "name": "state", "type": "string", "allowed_values": ["correct", "wrong", "dim", "hidden"] }
      ]
    },
    {
      "keyword": "VerifyEndScreen",
      "description": "Assert that the end screen is visible with the expected final prize",
      "parameters": [{ "name": "expected_prize", "type": "string" }]
    },
    {
      "keyword": "VerifyLeaderboardEntry",
      "description": "Assert that a given username appears in the leaderboard",
      "parameters": [{ "name": "username", "type": "string" }]
    },
    {
      "keyword": "WaitForSeconds",
      "description": "Pause execution for a given number of seconds",
      "parameters": [{ "name": "seconds", "type": "integer" }]
    }
  ],
  "test_suites": [
    {
      "suite_id": "TS-01",
      "title": "Successful Full Game — Win",
      "description": "A player enters a username, answers all 10 questions correctly, and wins 1,000,000 TL",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "TestPlayer" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Answer Q1 correctly" },
        { "step": 5, "keyword": "VerifyPrizeLadder", "data": { "expected_prize": "1.000 TL" } },
        { "step": 6, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Answer Q2 correctly" },
        { "step": 7, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Answer Q3 — milestone" },
        { "step": 8, "keyword": "VerifyPrizeLadder", "data": { "expected_prize": "5.000 TL" } },
        { "step": 9, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Answer Q4–Q10 correctly (repeat for each)" },
        { "step": 10, "keyword": "VerifyEndScreen", "data": { "expected_prize": "1.000.000 TL" } },
        { "step": 11, "keyword": "VerifyLeaderboardEntry", "data": { "username": "TestPlayer" } }
      ]
    },
    {
      "suite_id": "TS-02",
      "title": "Wrong Answer Before Milestone — Zero Prize",
      "description": "A player answers incorrectly on Q2 (before the first safe haven) and ends with 0 TL",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "LoseEarly" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Answer Q1 correctly" },
        { "step": 5, "keyword": "SelectMCQAnswer", "data": { "index": 3 }, "comment": "Answer Q2 incorrectly" },
        { "step": 6, "keyword": "VerifyAnswerState", "data": { "index": 3, "state": "wrong" } },
        { "step": 7, "keyword": "VerifyEndScreen", "data": { "expected_prize": "0 TL" } }
      ]
    },
    {
      "suite_id": "TS-03",
      "title": "Safe Haven Preserved — Lose After Q3 Milestone",
      "description": "A player reaches the Q3 milestone then loses — final prize should be 5,000 TL",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "SafeHavenTest" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Q1 correct" },
        { "step": 5, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Q2 correct" },
        { "step": 6, "keyword": "SelectMCQAnswer", "data": { "index": 0 }, "comment": "Q3 correct — milestone reached" },
        { "step": 7, "keyword": "VerifyPrizeLadder", "data": { "expected_prize": "5.000 TL" } },
        { "step": 8, "keyword": "SelectMCQAnswer", "data": { "index": 3 }, "comment": "Q4 wrong answer" },
        { "step": 9, "keyword": "VerifyEndScreen", "data": { "expected_prize": "5.000 TL" } }
      ]
    },
    {
      "suite_id": "TS-04",
      "title": "Empty Username Rejected",
      "description": "A player attempts to start without entering a name",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "ClickStartGame", "data": {} },
        { "step": 3, "keyword": "VerifyErrorMessage", "data": { "expected_text": "Please enter a username before starting." } }
      ]
    },
    {
      "suite_id": "TS-05",
      "title": "50:50 Lifeline on MCQ",
      "description": "Player uses 50:50 on an MCQ question and verifies two options are removed",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "FiftyFiftyTest" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "UseLifeline", "data": { "lifeline": "fifty" } },
        { "step": 5, "keyword": "VerifyAnswerState", "data": { "index": 1, "state": "hidden" }, "comment": "One of the two wrong options hidden" },
        { "step": 6, "keyword": "VerifyAnswerState", "data": { "index": 2, "state": "hidden" }, "comment": "Second wrong option hidden" }
      ]
    },
    {
      "suite_id": "TS-06",
      "title": "Phone a Friend on FITB Question",
      "description": "Player uses Phone lifeline on a Fill in the Blank question and receives a valid text hint",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "PhoneFITB" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "UseLifeline", "data": { "lifeline": "phone" } },
        { "step": 5, "keyword": "SelectExpert", "data": { "expert_name": "Dr. Al-Hassan" } },
        { "step": 6, "keyword": "CloseModal", "data": {} },
        { "step": 7, "keyword": "TypeFITBAnswer", "data": { "text": "test plan" } }
      ]
    },
    {
      "suite_id": "TS-07",
      "title": "Matching Question — Full Interaction",
      "description": "Player completes a Matching question using bi-directional selection, removes all, re-pairs, and submits",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "MatchTest" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "MatchPair", "data": { "left_index": 0, "right_text": "Concepts & definitions" } },
        { "step": 5, "keyword": "MatchPair", "data": { "left_index": 1, "right_text": "Test processes" } },
        { "step": 6, "keyword": "MatchPair", "data": { "left_index": 2, "right_text": "Test documentation" } },
        { "step": 7, "keyword": "MatchPair", "data": { "left_index": 3, "right_text": "Test design techniques" } },
        { "step": 8, "keyword": "ClickRemoveAll", "data": {} },
        { "step": 9, "keyword": "MatchPair", "data": { "left_index": 0, "right_text": "Concepts & definitions" } },
        { "step": 10, "keyword": "MatchPair", "data": { "left_index": 1, "right_text": "Test processes" } },
        { "step": 11, "keyword": "MatchPair", "data": { "left_index": 2, "right_text": "Test documentation" } },
        { "step": 12, "keyword": "MatchPair", "data": { "left_index": 3, "right_text": "Test design techniques" } },
        { "step": 13, "keyword": "ClickConfirmAllPairs", "data": {} }
      ]
    },
    {
      "suite_id": "TS-08",
      "title": "Walk Away",
      "description": "Player walks away after answering Q3 and receives the current prize",
      "steps": [
        { "step": 1, "keyword": "OpenApplication", "data": { "url": "https://iso29119-millionaire.vercel.app" } },
        { "step": 2, "keyword": "EnterUsername", "data": { "username": "WalkTest" } },
        { "step": 3, "keyword": "ClickStartGame", "data": {} },
        { "step": 4, "keyword": "SelectMCQAnswer", "data": { "index": 0 } },
        { "step": 5, "keyword": "SelectMCQAnswer", "data": { "index": 0 } },
        { "step": 6, "keyword": "SelectMCQAnswer", "data": { "index": 0 } },
        { "step": 7, "keyword": "ClickWalkAway", "data": {} },
        { "step": 8, "keyword": "VerifyEndScreen", "data": { "expected_prize": "5.000 TL" } }
      ]
    }
  ]
}
